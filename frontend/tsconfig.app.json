{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [ "ES2020", "DOM", "DOM.Iterable" ],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true, /* Bundler mode (Vite) */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true, /* React JSX */
    "jsx": "react-jsx", /* Strict mode */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true, /* ⭐ Paths y alias correctos ⭐ */
    "baseUrl": "./src",
    "paths": {
      "@/*": [ "*" ],
      "@/lib/*": [ "lib/*" ],
      "@/types/*": [ "types/*" ],
      "@/modules/*": [ "modules/*" ],
      "@/shared/*": [ "shared/*" ]
    }
  },
  "include": [ "src" ],
  "references": [ { "path": "./tsconfig.node.json" } ]
}